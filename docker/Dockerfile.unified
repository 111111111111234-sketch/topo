ARG BASE_IMAGE=infra-registry-vpc.cn-wulanchabu.cr.aliyuncs.com/data-infra/fuyao:tangyx7-260601-stage4v4
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.title="conftopo-vlnce-patch"
LABEL org.opencontainers.image.description="patch existing stage4 image by rebuilding vlnce only"

ENV DEBIAN_FRONTEND=noninteractive
ENV MAX_JOBS=1
ENV TZ=Asia/Shanghai
ENV WORKSPACE=/workspace/tangyx7@xiaopeng.com
ENV CONFTopo_MAIN_ENV=conftopo-main
ENV CONFTopo_MAIN_PYTHON=/opt/conda/envs/conftopo-main/bin/python
ENV MAGNUM_LOG=quiet
ENV GLOG_minloglevel=2
ENV NVIDIA_DRIVER_CAPABILITIES=compute,graphics,utility,video,display
ENV __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json

ARG PIP_OPTIONS="-i https://nexus-wl.xiaopeng.link/repository/ai_infra_pypi_group/simple --timeout 600 --no-cache-dir"
ARG HABITAT_SIM_TAG=v0.1.7
ARG HABITAT_SIM_GIT=https://github.com/facebookresearch/habitat-sim.git

# ============================================================================
# A. 基于已有 stage4 镜像，仅补 conftopo-main 与 vlnce 所需内容
# 已有镜像中已包含 fuyao / goat / zsh / verify-envs
# ============================================================================
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      build-essential \
      cmake \
      ninja-build \
      libjpeg-dev \
      libglm-dev \
      libgl1-mesa-dev \
      libegl1-mesa-dev \
      libxrandr-dev \
      libxinerama-dev \
      libxcursor-dev \
      libxi-dev; \
    rm -rf /var/lib/apt/lists/*

RUN conda env remove -n conftopo-main -y || true

RUN conda create -n conftopo-main python=3.12 pip -y && \
        conda run -n conftopo-main pip install --no-cache-dir ${PIP_OPTIONS} \
            "setuptools<75" "packaging>=24.2" \
            numpy==1.26.4 scipy scikit-learn matplotlib==3.9.4 \
            pillow tqdm pyyaml networkx==3.2.1 \
            imageio imageio-ffmpeg h5py lmdb numba \
            opencv-python-headless \
            gym==0.26.2 hydra-core omegaconf yacs jsonlines \
            msgpack msgpack-numpy numpy-quaternion \
            'transformers>=4.40' timm==1.0.27 \
            open_clip_torch==3.3.0 ftfy regex \
            openai safetensors huggingface_hub gdown requests \
            tensorboardX easydict natsort

# ============================================================================
# B. 重建 vlnce
# 用新栈替换旧的 Python 3.8 + torch 1.9.1 + habitat-sim 0.1.7 binary 方案
# ============================================================================
RUN conda env remove -n vlnce -y || true

RUN conda create -n vlnce python=3.9 cmake "pip>=23,<24.4" -y

RUN conda run -n vlnce pip install --no-cache-dir \
    torch==2.8.0 torchvision==0.23.0 torchaudio==2.8.0 \
    --index-url https://download.pytorch.org/whl/cu128

RUN conda run -n vlnce pip install --no-cache-dir ${PIP_OPTIONS} \
    numpy==1.26.4 scipy scikit-learn matplotlib==3.9.4 \
    opencv-python==4.11.0.86 networkx==3.2.1 pillow tqdm pyyaml \
    gym==0.23.1 hydra-core omegaconf yacs jsonlines \
    imageio imageio-ffmpeg quaternion \
    h5py lmdb msgpack msgpack-numpy numba numpy-quaternion \
    transformers==4.12.5 tokenizers==0.10.3 timm==1.0.27 \
    tensorboardX easydict ftfy regex \
    open_clip_torch==3.3.0 openai safetensors huggingface_hub gdown requests \
    scikit-image sentencepiece sacremoses stanza shapely \
    bresenham dtw fastdtw progressbar2 gpustat \
    "protobuf>=3.20,<5" webdataset attrs

RUN conda run -n vlnce pip install --no-cache-dir \
    git+https://github.com/openai/CLIP.git || true

# ============================================================================
# C. 编译 habitat-sim 0.1.7
# 避免沿用旧二进制导致的 numba / quaternion / ABI 兼容问题
# ============================================================================
RUN git clone --depth 1 --branch ${HABITAT_SIM_TAG} ${HABITAT_SIM_GIT} /tmp/habitat-sim && \
    conda run -n vlnce pip install --no-cache-dir -r /tmp/habitat-sim/requirements.txt && \
    cd /tmp/habitat-sim && \
    conda run -n vlnce python setup.py install --headless --with-cuda && \
    rm -rf /tmp/habitat-sim

# ============================================================================
# D. 重装 conftopo-main / vlnce 侧源码安装
# goat 已存在，这里补 conftopo-main 和 vlnce 的 editable 包
# ============================================================================
COPY setup.py /opt/conftopo-src/setup.py
COPY conftopo /opt/conftopo-src/conftopo
COPY habitat-lab /opt/src/habitat-lab-v017/
COPY docker_build/verify-envs.sh /opt/conftopo-env/bin/verify-envs.sh

RUN mkdir -p /opt/conftopo-env/bin && \
    touch /opt/src/habitat-lab-v017/README.md /opt/src/habitat-lab-v017/LICENSE && \
    chmod +x /opt/conftopo-env/bin/verify-envs.sh

RUN conda run -n conftopo-main pip install --no-cache-dir -e /opt/conftopo-src ${PIP_OPTIONS}

RUN env -u PIP_CONSTRAINT env -u LD_LIBRARY_PATH conda run -n vlnce pip install --no-cache-dir \
    -e /opt/src/habitat-lab-v017 --no-deps && \
    env -u PIP_CONSTRAINT env -u LD_LIBRARY_PATH conda run -n vlnce pip install --no-cache-dir \
    -e /opt/conftopo-src

# ============================================================================
# E. 回补 conftopo-main / vlnce 激活脚本和 zsh 别名
# ============================================================================
RUN mkdir -p /opt/conda/envs/conftopo-main/etc/conda/activate.d /opt/conda/envs/conftopo-main/etc/conda/deactivate.d \
                         /opt/conda/envs/vlnce/etc/conda/activate.d /opt/conda/envs/vlnce/etc/conda/deactivate.d && \
        printf '%s\n' \
            '#!/bin/bash' \
            'export _CONFTOPO_SAVED_LD_LIBRARY_PATH="${LD_LIBRARY_PATH:-}"' \
            'unset LD_LIBRARY_PATH' \
            > /opt/conda/envs/conftopo-main/etc/conda/activate.d/unset_ld_path.sh && \
        printf '%s\n' \
            '#!/bin/bash' \
            'export LD_LIBRARY_PATH="${_CONFTOPO_SAVED_LD_LIBRARY_PATH:-}"' \
            'unset _CONFTOPO_SAVED_LD_LIBRARY_PATH' \
            > /opt/conda/envs/conftopo-main/etc/conda/deactivate.d/restore_ld_path.sh && \
    printf '%s\n' \
      '#!/bin/bash' \
      'export _CONFTOPO_SAVED_LD_LIBRARY_PATH="${LD_LIBRARY_PATH:-}"' \
      'unset LD_LIBRARY_PATH' \
      > /opt/conda/envs/vlnce/etc/conda/activate.d/unset_ld_path.sh && \
    printf '%s\n' \
      '#!/bin/bash' \
      'export LD_LIBRARY_PATH="${_CONFTOPO_SAVED_LD_LIBRARY_PATH:-}"' \
      'unset _CONFTOPO_SAVED_LD_LIBRARY_PATH' \
      > /opt/conda/envs/vlnce/etc/conda/deactivate.d/restore_ld_path.sh && \
        chmod +x /opt/conda/envs/conftopo-main/etc/conda/activate.d/unset_ld_path.sh /opt/conda/envs/conftopo-main/etc/conda/deactivate.d/restore_ld_path.sh \
                         /opt/conda/envs/vlnce/etc/conda/activate.d/unset_ld_path.sh /opt/conda/envs/vlnce/etc/conda/deactivate.d/restore_ld_path.sh

RUN grep -q 'alias conftopo-main=' /root/.zshrc 2>/dev/null || \
        printf '%s\n' \
            'alias conftopo-main="conda activate conftopo-main"' \
            >> /root/.zshrc

RUN grep -q 'alias conftopo-vlnce=' /root/.zshrc 2>/dev/null || \
    printf '%s\n' \
      'alias conftopo-vlnce="conda activate vlnce"' \
      'alias conftopo-etp="conda activate vlnce"' \
      >> /root/.zshrc

WORKDIR ${WORKSPACE}

RUN /opt/conftopo-env/bin/verify-envs.sh || \
    (echo "WARN: verify-envs failed at build time; re-run: verify-envs" && true)

ENTRYPOINT ["tini", "-s", "--", "/bin/zsh", "-l"]